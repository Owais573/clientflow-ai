# ==============================================================================
# ClientFlow AI — Environment Variables
# ==============================================================================
# Copy this file to `.env` and fill in your actual values.
# Command: copy .env.example .env
# ==============================================================================


# ==============================================================================
# DATABASE (PostgreSQL — Docker)
# ==============================================================================
# These are used by both docker-compose.yml and the FastAPI backend.
# Change the password to something secure.

POSTGRES_USER=clientflow
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=clientflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full database URL for FastAPI/SQLAlchemy (async)
DATABASE_URL=postgresql+asyncpg://clientflow:your_secure_password_here@localhost:5432/clientflow

# n8n database (same PostgreSQL server, different database)
N8N_DB_NAME=n8n


# ==============================================================================
# OPENAI
# ==============================================================================
# Get your API key from: https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4.1


# ==============================================================================
# TAVILY (AI-Powered Web Search)
# ==============================================================================
# Get your API key from: https://app.tavily.com/

TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ==============================================================================
# ZOHO CRM (Indian Data Center)
# ==============================================================================
# Follow API_SETUP_GUIDE.md → Steps 1 & 2 to get these values.
# API Console: https://api-console.zoho.in/

ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_GRANT_TOKEN=1000.XXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXX
ZOHO_USER_EMAIL=your-zoho-email@example.com
ZOHO_REDIRECT_URI=http://localhost:8000/api/zoho/callback

# Zoho Data Center — use zoho.in for India, zoho.com for US, zoho.eu for EU
ZOHO_DOMAIN=zoho.in
ZOHO_API_BASE_URL=https://www.zohoapis.in
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in


# ==============================================================================
# SLACK (Notifications)
# ==============================================================================
# Follow API_SETUP_GUIDE.md → Step 4 to get the webhook URL.
# Channel: #clientflow-alerts in SupDevX workspace

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE/YOUR_BOT/YOUR_TOKEN
SLACK_CHANNEL=#clientflow-alerts


# ==============================================================================
# n8n (Workflow Automation — Docker)
# ==============================================================================
# n8n runs in Docker on port 5678.
# This is the webhook URL that FastAPI uses to trigger n8n workflows.

N8N_WEBHOOK_URL=http://localhost:5678/webhook/client-onboarding
N8N_BASE_URL=http://localhost:5678

# n8n encryption key — generate a random string (used to encrypt credentials in n8n)
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
N8N_ENCRYPTION_KEY=your_random_encryption_key_here


# ==============================================================================
# GOOGLE WORKSPACE (Handled via n8n — NOT in backend code)
# ==============================================================================
# These credentials are entered DIRECTLY into n8n's credential manager,
# not used by FastAPI. Listed here for reference/documentation only.
#
# Follow API_SETUP_GUIDE.md → Step 3 to get these values.
# Google Cloud Console: https://console.cloud.google.com/
#
# GOOGLE_CLIENT_ID=XXXXXXXXXXXX.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXX
#
# NOTE: Enter these in n8n UI → Settings → Credentials → Google OAuth2


# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================

# FastAPI
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# Next.js Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# Environment
ENVIRONMENT=development
DEBUG=true
