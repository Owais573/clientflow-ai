{
  "name": "Client Onboarding Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "client-onboarding",
        "options": {}
      },
      "id": "1",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ],
      "webhookId": "client-onboarding"
    },
    {
      "parameters": {
        "channel": "={{ $env.SLACK_CHANNEL || '#clientflow-alerts' }}",
        "text": "=🚀 *New Client Onboarded!* \n\n*Company:* {{ $json.body.company_name }}\n*Email:* {{ $json.body.contact_email }}\n*Workflow ID:* {{ $json.body.workflow_id }}\n\nResearch summary: {{ $json.body.research_summary }}",
        "otherOptions": {}
      },
      "id": "2",
      "name": "Slack Notification",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.1,
      "position": [
        500,
        150
      ],
      "credentials": {
        "slackApi": {
          "id": "",
          "name": "Slack account"
        }
      }
    },
    {
      "parameters": {
        "resource": "folder",
        "name": "={{ $json.body.company_name }} - Client Onboarding",
        "options": {}
      },
      "id": "3",
      "name": "Google Drive Folder",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 2,
      "position": [
        500,
        350
      ],
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "operation": "create",
        "title": "={{ $('Webhook Trigger').item.json.body.company_name }} - Proposal",
        "folderId": "={{ $json.id }}",
        "options": {}
      },
      "id": "4",
      "name": "Google Docs Proposal",
      "type": "n8n-nodes-base.googleDocs",
      "typeVersion": 1,
      "position": [
        750,
        350
      ],
      "credentials": {
        "googleDocsOAuth2Api": {
          "id": "",
          "name": "Google Docs account"
        }
      }
    },
    {
      "parameters": {
        "resource": "document",
        "operation": "update",
        "documentURL": "={{ $json.documentId }}",
        "actionsUi": {
          "actionFields": [
            {
              "action": "insert",
              "object": "text",
              "text": "={{ $('Webhook Trigger').item.json.body.proposal_draft }}",
              "locationChoice": "endOfSegmentLocation",
              "insertSegment": "body"
            }
          ]
        },
        "options": {}
      },
      "id": "7",
      "name": "Google Docs Append Text",
      "type": "n8n-nodes-base.googleDocs",
      "typeVersion": 1,
      "position": [
        950,
        350
      ],
      "credentials": {
        "googleDocsOAuth2Api": {
          "id": "",
          "name": "Google Docs account"
        }
      }
    },
    {
      "parameters": {
        "sendTo": "={{ $('Webhook Trigger').item.json.body.contact_email }}",
        "subject": "=Welcome to ClientFlow AI, {{ $('Webhook Trigger').item.json.body.company_name }}!",
        "message": "=Hi there,\n\nWelcome to ClientFlow AI! We are thrilled to start working with you. Our team is currently reviewing your project details and will share a customized proposal with you shortly.\n\nBest regards,\nThe Team",
        "options": {}
      },
      "id": "5",
      "name": "Gmail Welcome",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        500,
        550
      ],
      "credentials": {
        "gmailOAuth2": {
          "id": "",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8000/api/webhooks/n8n",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"workflow_id\": {{ $('Webhook Trigger').item.json.body.workflow_id }},\n  \"status\": \"running\",\n  \"step\": \"n8n_pipeline_completed\",\n  \"message\": \"n8n workflow executed successfully (Drive, Docs, Slack, Gmail)\"\n}",
        "options": {}
      },
      "id": "6",
      "name": "FastAPI Callback",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1150,
        350
      ]
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [
        [
          {
            "node": "Slack Notification",
            "type": "main",
            "index": 0
          },
          {
            "node": "Google Drive Folder",
            "type": "main",
            "index": 0
          },
          {
            "node": "Gmail Welcome",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Google Drive Folder": {
      "main": [
        [
          {
            "node": "Google Docs Proposal",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Google Docs Proposal": {
      "main": [
        [
          {
            "node": "Google Docs Append Text",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Google Docs Append Text": {
      "main": [
        [
          {
            "node": "FastAPI Callback",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
